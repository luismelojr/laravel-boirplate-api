{
    "mcpServers": {
        "laravel-boost": {
            "command": "vendor/bin/sail",
            "args": [
                "artisan",
                "boost:mcp"
            ]
        },
        "nuxt": {
            "command": "npx",
            "args": [
                "mcp-remote",
                "https://nuxt.com/mcp"
            ]
        }
    }
}
